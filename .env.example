# ── LLM & Embedding ──────────────────────────────────────────────────
GEMINI_API_KEY=your_google_ai_studio_key_here
GEMINI_GENERATION_MODEL=gemini-3-flash-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIM=768

# ── Vector Database ──────────────────────────────────────────────────
DATA_DIR=data
CHROMA_COLLECTION=bank_mandiri_multimodal_rag

# ── RAG Pipeline ─────────────────────────────────────────────────────
ENABLE_VISUAL_CAPTIONING=true
VISUAL_CAPTION_PAGES=4,6,8,9
TOP_K_DEFAULT=5
MAX_CHUNK_CHARS=1400
CHUNK_OVERLAP_CHARS=180

# ── Development ──────────────────────────────────────────────────────
# Keep true for local smoke tests without API calls.
# For the real demo, set GEMINI_API_KEY so ingestion/query use Gemini.
LOCAL_FALLBACK_EMBEDDINGS=true
